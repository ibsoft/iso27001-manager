FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-at-least-64-chars
DATABASE_URL=sqlite:///../instance/isms.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/iso27001

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@example.com

SESSION_TYPE=filesystem
# For production use redis:
# SESSION_TYPE=redis
# SESSION_REDIS=redis://localhost:6379/0

TOTP_ISSUER_NAME=ISO27001-Manager
ADMIN_EMAIL=admin@example.com
